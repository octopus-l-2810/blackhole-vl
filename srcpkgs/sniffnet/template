revision=1
archs="x86_64* aarch64*"
build_style=cargo
hostmakedepends="pkg-config"
makedepends="libpcap-devel alsa-lib-devel fontconfig-devel gtk+3-devel"
depends="libpcap alsa-lib fontconfig gtk+3 xdg-desktop-portal zenity freetype"
