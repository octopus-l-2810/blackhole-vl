# Template file for 'plank-reloaded'
pkgname=plank-reloaded
version=0.11.167
revision=1
build_style=meson
build_helper=qemu
hostmakedepends="intltool libgee08-devel glib-devel pkg-config python3 libxml2 vala git
 desktop-file-utils gtk-update-icon-cache $(vopt_if dbusmenu 'libdbusmenu-glib-devel libdbusmenu-gtk3-devel')"
makedepends="bamf-devel libgee08-devel libwnck-devel vala-devel gnome-menus-devel
 $(vopt_if dbusmenu 'libdbusmenu-glib-devel libdbusmenu-gtk3-devel')"
short_desc="Elegant, simple, clean dock, reloaded version"
maintainer="Octopus_L <octopus.l.2810@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/zquestz/plank-reloaded"
distfiles="${homepage}/archive/refs/tags/${version}.tar.gz"
checksum=7c24a46bff96eb86f1dfc820c843d78a14634077cbcbb3695b2cb1aad184c536
conflicts="plank plank-devel"

build_options="dbusmenu"
desc_option_dbusmenu="Enable dynamic quicklist support over dbusmenu"
build_options_default="dbusmenu"

python_version=3
make_check=no # Plank requires a GUI for tests

plank-reloaded-devel_package() {
	short_desc+=" - development files"
	depends="${sourcepkg}>=${version}_${revision} cairo-devel libgee08-devel
	 libglib-devel gtk+3-devel gdk-pixbuf-devel bamf-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.so"
		vmove usr/share/vala
	}
}
